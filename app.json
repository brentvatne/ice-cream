{
  "expo": {
    "name": "Vancouver Ice Cream Festival",
    "slug": "ice-cream",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ice-cream",
    "platforms": [
      "ios"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.brents.ice-cream",
      "icon": "./assets/app.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-maps",
        {
          "requestLocationPermission": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "This app uses your location to show nearby ice cream spots on the map."
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-image",
      "expo-sqlite",
      "expo-asset",
      "@bacons/apple-colors",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ac987f47-3613-45a5-b7d2-a2fee1401b09"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ac987f47-3613-45a5-b7d2-a2fee1401b09"
    }
  }
}
